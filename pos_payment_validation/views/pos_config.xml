<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_payment_validation_config_view_form" model="ir.ui.view">
        <field name="name">pos_payment_validation_config_view_form</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='other_devices']" position="after">
                <setting id="qty_limit" string="Qty Limitation">
                    <field name="qty_restriction"/>
                    <div class="content-group" invisible="not qty_restriction">
                        <field name="qty_limit_count"/>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
