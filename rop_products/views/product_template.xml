<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="rop_product_form_inherit" model="ir.ui.view">
            <field name="name">rop_product_form_inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">

                <xpath expr="//div[@name='options']" position="inside">
                    <span class="d-inline-flex align-items-center mr-2">
                        <field name="has_rop"/>
                        <label for="has_rop"/>
                        <div invisible="not has_rop">
                            <label for="rop_count"/>
                            <field name="rop_count"/>
                        </div>
                    </span>
                </xpath>

                <xpath expr="//div[@name='button_box']" position="inside">
                    <button class="oe_stat_button"
                            name="action_get_rop_products"
                            type="object"
                            string="ROP Products"
                            icon="fa-file-text-o" invisible="not has_rop"/>
                </xpath>

            </field>
        </record>

    </data>
</odoo>