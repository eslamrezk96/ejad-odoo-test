<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_project_kanban_sql_metric" model="ir.ui.view">
        <field name="name">project.project.kanban.sql.metric</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project_kanban"/>
        <field name="arch" type="xml">

            <xpath expr="//kanban" position="attributes">
                <attribute name="js_class">project_kanban_sql_metric</attribute>
            </xpath>

            <xpath expr="//kanban/templates" position="before">
                <field name="x_kanban_total_boq"/>
                <field name="x_kanban_delivered"/>
                <field name="x_kanban_remaining"/>
            </xpath>

        </field>
    </record>

</odoo>
