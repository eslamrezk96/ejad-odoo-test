<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_cash_now_config_view_form" model="ir.ui.view">
        <field name="name">pos_cash_now_config_view_form</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='other_devices']" position="after">
                <setting id="cash_now" string="Enable Cash Now">
                    <field name="enable_instance_payment"/>
                    <div class="content-group" invisible="not enable_instance_payment">
                        <label for="default_pos_partner_id"/>
                        <field name="default_pos_partner_id"/>
                        <label for="default_payment_method_id"/>
                        <field name="default_payment_method_id"/>
                        <label for="instance_payment_label"/>
                        <field name="instance_payment_label"/>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
