<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_ea_entity_version_wizard_form" model="ir.ui.view">
        <field name="name">ea.entity.version.wizard.form</field>
        <field name="model">ea.entity.version.wizard</field>
        <field name="arch" type="xml">
            <form string="Create New Version">
                <group>
                    <field name="transition_id" options="{'no_create': True}"/>
                </group>
                <footer>
                    <button name="action_create_version" type="object" string="Create Version" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
