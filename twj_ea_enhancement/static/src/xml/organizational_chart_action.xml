<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <div
        t-name="twj_ea_enhancement.OrganizationalChartAction"
        class="o_twj_org_chart_action"
        t-att-dir="getRootDirection()"
    >
        <div class="o_twj_org_chart_header">
            <h1 class="mb-1" t-esc="getTitle()"/>
            <p class="mb-0" t-esc="getSubtitle()"/>
        </div>
        <div class="o_twj_org_chart_frame_wrap">
            <iframe
                class="o_twj_org_chart_iframe"
                t-att-src="chartUrl"
                t-att-title="getTitle()"
            />
        </div>
    </div>
</templates>
