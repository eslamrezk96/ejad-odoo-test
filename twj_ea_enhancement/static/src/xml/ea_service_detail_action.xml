<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <div
        t-name="twj_ea_enhancement.EaServiceDetailAction"
        class="o_twj_ea_service_detail_action"
        t-att-dir="getRootDirection()"
    >
        <div class="o_twj_ea_service_detail_header">
            <h1 class="mb-1" t-esc="getTitle()"/>
            <p class="mb-0" t-esc="getSubtitle()"/>
        </div>
        <div class="o_twj_ea_service_detail_frame_wrap">
            <iframe
                class="o_twj_ea_service_detail_iframe"
                t-att-src="eaServiceDetailUrl"
                t-att-title="getTitle()"
            />
        </div>
    </div>
</templates>
